<?xml version="1.0" encoding="UTF-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="by.intontrainer"
    android:versionCode="1"
    android:versionName="0.1"
    android:installLocation="auto">

    <!-- Audio recording permission (required) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <!-- Read external storage (for opening WAV files from file picker) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <!-- Android 13+ granular media permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO"/>
    <!-- Write (for saving recordings if needed) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"/>

    <!-- Require a microphone -->
    <uses-feature android:name="android.hardware.microphone" android:required="true"/>

    <application
        android:name="org.qtproject.qt.android.bindings.QtApplication"
        android:label="Intonation Trainer"
        android:theme="@style/AppTheme"
        android:hardwareAccelerated="true"
        android:supportsRtl="true"
        android:allowBackup="false"
        android:extractNativeLibs="true">

        <activity
            android:name="org.qtproject.qt.android.bindings.QtActivity"
            android:label="Intonation Trainer"
            android:screenOrientation="portrait"
            android:launchMode="singleTop"
            android:configChanges="orientation|uiMode|screenLayout|screenSize|smallestScreenSize|layoutDirection|locale|fontScale|keyboard|keyboardHidden|navigation|mcc|mnc|density"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- androiddeployqt injects android.app.lib_name automatically -->
            <meta-data android:name="android.app.lib_name" android:value="appinton-trainer-2"/>
            <meta-data android:name="android.app.extract_android_style" android:value="minimal"/>
        </activity>
    </application>
</manifest>
